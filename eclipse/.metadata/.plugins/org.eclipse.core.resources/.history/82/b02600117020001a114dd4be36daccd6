package com.test.dao;

import java.sql.PreparedStatement;
import java.sql.SQLException;

import com.test.db.DB;
import com.test.model.User;

public class UserDaoImpl  implements UserDao{

	@Override
	public void Signup(User u) {
		
		String sql="insert into user(fname,lname,username,password) values(?,?,?,?)";
		try {
			PreparedStatement pstat=DB.getDb().prepareStatement(sql);
			pstat.setString(1,u.getFname());
			pstat.setString(2, u.getLname());
			pstat.setString(3, u.getUsername());
			pstat.setString(4, u.getPassword());
			
		} catch (SQLException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
		
		
		
	}

