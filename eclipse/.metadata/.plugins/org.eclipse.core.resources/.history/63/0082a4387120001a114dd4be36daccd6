package com.test.dao;

import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;

import com.test.db.DB;
import com.test.model.User;

public class UserDaoImpl implements UserDao {

	@Override
	public void Signup(User u) {

		String sql = "insert into user(fname,lname,username,password) values(?,?,?,?)";
		try {
			PreparedStatement pstat = DB.getDb().prepareStatement(sql);
			pstat.setString(1, u.getFname());
			pstat.setString(2, u.getLname());
			pstat.setString(3, u.getUsername());
			pstat.setString(4, u.getPassword());
			pstat.execute();

		} catch (SQLException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}

	}

	public User login(String un, String pw) {
		String sql="select * from user where username='"+un+"' and password='"+pw+"'    ";
		try {
			Statement stm=DB.getDb().createStatement();
			ResultSet rs =stm.executeQuery(sql);
			if(rs.next())
			{
				
				User u=new User();
				u.setId(rs.getInt("id"));
				
				u.setLname(rs.getString("lname"));
				u.setUsername(rs.getString("fname"));
				u.setPassword(rs.getString("password"));
				
			}
			
		} catch (SQLException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
		return null;
	}

}
